BOT_TOKEN=
OPENAI_API_KEY=

# Super admins: comma-separated Telegram user IDs with FULL control.
# They can add/remove regular admins (/add_admin, /remove_admin), take backups
# (/backup), and choose whether their own reports are named or anonymous.
# (Legacy ADMIN_IDS is still read as a fallback if SUPER_ADMIN_IDS is unset.)
SUPER_ADMIN_IDS=12345,67890

# Optional
# OPENAI_MODEL=gpt-4o-mini
# DB_PATH=bugs.db

# --- Using OpenRouter (or any OpenAI-compatible gateway) instead of OpenAI ---
# Put your OpenRouter key in OPENAI_API_KEY above (starts with sk-or-v1-...),
# then set these two:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
